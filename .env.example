# Environment Variables
# Copy this file to .env and fill in your values

# Webhook URL for form submissions
# Example: https://hook.eu1.make.com/your-webhook-id
VITE_WEBHOOK_URL=

# API Key for webhook authentication
VITE_API_KEY=

# AI Chatbot API (optional - uses simulated responses by default)
VITE_CHATBOT_API_URL=
VITE_CHATBOT_API_KEY=
