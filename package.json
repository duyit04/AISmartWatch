{
  "name": "ai-smartwatch",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx src/server/index.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:server\"",
    "build": "vite build",
    "deploy": "npm run build && wrangler pages deploy ./dist --project-name=ai-smartwatch --commit-dirty=true",
    "deploy:preview": "npm run build && wrangler pages deploy ./dist --project-name=ai-smartwatch --branch=preview",
    "preview": "vite preview",
    "lint": "oxlint src",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20250501.0",
    "@hono/node-server": "^1.13.8",
    "@icons-pack/react-simple-icons": "^13.11.1",
    "hono": "^4.7.11",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^2.1.9",
    "concurrently": "^9.1.2",
    "happy-dom": "^15.11.7",
    "oxlint": "^1.71.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.19.2",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^2.1.9",
    "wrangler": "^4.12.1"
  }
}
